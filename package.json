{
  "name": "@rchapkailo/shared",
  "version": "1.0.1",
  "files": [
    "index.ts",
    "README.md"
  ],
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist",
    "test": "bun test",
    "lint": "oxlint .",
    "format:check": "oxfmt --check \"**/*.js\" \"**/*.ts\"",
    "format:write": "oxfmt \"**/*.js\" \"**/*.ts\"",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "simple-git-hooks": "latest"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run format:write"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
